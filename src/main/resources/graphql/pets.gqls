# static description of the API pets.gqls
#отримання даних (queries), а й оновлення (mutations) та підписки (subscriptions)

extend type Query {
    pets(kind: PetKind): [Pet!]!
    pet(id: ID, name: String): Pet
}

type Pet {
    id: Long
    name: String
    color: String
    kind: PetKind
    friends: [Pet]
    owners: [Person!]
}

enum PetKind {
    CAT
    DOG
    BIRD
}

type Person {
    id: Long
    name: String
}
